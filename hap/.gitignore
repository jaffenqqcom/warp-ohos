# ═══════════════════════════════════════════════════════════
#  hap — HarmonyOS HAP 项目
# ═══════════════════════════════════════════════════════════

# ── hvigor 构建缓存 ───────────────────────────────────
.hvigor/

# ── CMake/Ninja 构建中间文件 ──────────────────────────
entry/.cxx/

# ── CMake staging（libentry.so 临时输出目录） ─────────
entry/.cmake_staging/

# ── HAP 打包输出 ──────────────────────────────────────
entry/build/

# ── Rust 预编译 .so（由 build-vm.sh 生成） ──────────
entry/libs/arm64-v8a/libwarp.so

# ── npm/ohpm 依赖 ─────────────────────────────────────
oh_modules/
entry/oh_modules/

# ── DevEco Studio IDE 配置/缓存 ───────────────────────
.bitfun/

# ── Claude Code 临时文件 ──────────────────────────────
.remember/

# ── 机器相关的 SDK/NDK 路径 ───────────────────────────
local.properties

# ── 自动生成的 clang-tidy 配置 ────────────────────────
.clang-tidy
