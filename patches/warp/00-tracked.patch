+/// Resolve the openharmony-ability native_ability directory path from cargo metadata
+/// and write it to OUT_DIR/ohos-ability-path.txt for HAP build scripts.
+#[cfg(target_env = "ohos")]
+fn resolve_openharmony_ability_path() {
+    let output = Command::new("cargo")
+        .args(["metadata", "--format-version", "1", "--no-deps"])
+        .output()
+        .expect("failed to execute cargo metadata");
+    if !output.status.success() {
+        return;
+    }
+    let stdout = String::from_utf8(output.stdout).unwrap_or_default();
+    let target_str = r#""name":"openharmony-ability""#;
+    if let Some(pos) = stdout.find(target_str) {
+        let remaining = &stdout[pos..];
+        if let Some(mp_start) = remaining.find(r#""manifest_path":""#) {
+            let val_start = mp_start + 18;
+            if let Some(val_end) = remaining[val_start..].find('"') {
+                let manifest = &remaining[val_start..val_start + val_end];
+                let native_ability = std::path::Path::new(manifest)
+                    .parent()
+                    .unwrap()
+                    .parent()
+                    .unwrap()
+                    .parent()
+                    .unwrap()
+                    .join("native_ability");
+                if native_ability.exists() {
+                    let out_path = std::path::Path::new(
+                        &env::var("OUT_DIR").unwrap(),
+                    )
+                    .join("ohos-ability-path.txt");
+                    let _ = fs::write(&out_path, native_ability.canonicalize().unwrap().to_string());
+                }
+            }
+        }
+    }
+}
+
+#[cfg(not(target_env = "ohos"))]
+fn resolve_openharmony_ability_path() {}
