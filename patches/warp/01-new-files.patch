+++ b/script/ohos/install_build_deps
@@ -0,0 +1,85 @@
+#!/usr/bin/env bash
+set -eo pipefail
+
+# §16.6 — OHOS 构建依赖安装脚本
+#
+# 安装鸿蒙 NDK、rustup target、ohos-clang-wrapper。
+# 在开发机上运行（macOS 或 Linux），开发机需可访问鸿蒙 SDK。
+
+REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/../.. && pwd)"
+cd "${REPO_ROOT}"
+
+echo "Installing OHOS build dependencies..."
+
+# ── 1. 安装鸿蒙 NDK ──────────────────────────────────────────────────
+#
+# 鸿蒙 NDK 提供 OHOS 交叉编译工具链（clang、sysroot）。
+# 推荐安装到 $HOME/ohos-sdk/ 目录，或设置 OHOS_NDK_HOME 环境变量指定路径。
+#
+# 下载地址（需登录 HarmonyOS 开发者联盟）：
+#   https://developer.huawei.com/consumer/cn/download/
+#
+# 解压后目录结构：
+#   ${OHOS_NDK_HOME}/
+#     native/
+#       sysroot/
+#       llvm/
+#       build/
+#
+# 本脚本检测 OHOS_NDK_HOME 环境变量，若未设置则尝试默认路径。
+
+if [[ -z "${OHOS_NDK_HOME:-}" ]]; then
+  if [[ -d "${HOME}/ohos-sdk/native" ]]; then
+    export OHOS_NDK_HOME="${HOME}/ohos-sdk"
+    echo "Found OHOS NDK at OHOS_NDK_HOME=${OHOS_NDK_HOME}"
+  elif [[ -d "/data/ohos-sdk/native" ]]; then
+    export OHOS_NDK_HOME="/data/ohos-sdk"
+    echo "Found OHOS NDK at OHOS_NDK_HOME=${OHOS_NDK_HOME}"
+  else
+    echo "Warning: OHOS_NDK_HOME is not set and no default OHOS NDK installation found."
+    echo "Please install OHOS NDK from HarmonyOS developer website and set OHOS_NDK_HOME."
+    echo "  e.g. export OHOS_NDK_HOME=\$HOME/ohos-sdk"
+    echo "Skipping NDK verification..."
+  fi
+else
+  echo "Using OHOS_NDK_HOME=${OHOS_NDK_HOME}"
+fi
+
+# ── 2. 安装 rustup target ────────────────────────────────────────────
+#
+# 添加 aarch64-unknown-linux-ohos Rust 编译目标。
+# 需要 rustup 1.25+ 和 Rust 1.80+ 支持。
+# 早期 Rust 版本可能需要 nightly。
+
+echo "Adding rustup target: aarch64-unknown-linux-ohos"
+rustup target add aarch64-unknown-linux-ohos 2>/dev/null || {
+  echo "Warning: rustup target add aarch64-unknown-linux-ohos failed."
+  echo "This target may need a nightly Rust toolchain or rustup 1.25+."
+  echo "Attempting with nightly..."
+  rustup target add aarch64-unknown-linux-ohos --toolchain nightly 2>/dev/null || {
+    echo "Error: Could not add aarch64-unknown-linux-ohos target."
+    echo "Ensure rustup 1.25+ and suitable Rust toolchain is installed."
+    exit 1
+  }
+}
+
+# ── 3. 验证 Cargo 可访问 OHOS 编译器 ─────────────────────────────────
+#
+# OHOS 交叉编译通过 .cargo/config.toml 的 [target.aarch64-unknown-linux-ohos] 段
+# 配置 linker。若用户尚未配置，给出提示。
+
+if [[ -n "${OHOS_NDK_HOME:-}" ]]; then
+  echo "Verifying OHOS clang availability..."
+  OHOS_CLANG="${OHOS_NDK_HOME}/native/llvm/bin/clang"
+  if [[ -f "${OHOS_CLANG}" ]]; then
+    echo "Found OHOS clang: ${OHOS_CLANG}"
+    echo "Configure Cargo linker via .cargo/config.toml:"
+    echo "  [target.aarch64-unknown-linux-ohos]"
+    echo "  linker = \"${OHOS_CLANG}\""
+  else
+    echo "Warning: OHOS clang not found at ${OHOS_CLANG}"
+    echo "Ensure NDK is correctly extracted."
+  fi
+fi
+
+echo "OHOS build dependencies check complete."
