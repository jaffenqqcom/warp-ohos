+/// Resolve a linker binary for LD env var.
+/// Tries the given name first, then falls back to alternatives.
+fn resolve_ld() -> PathBuf {
+    let candidates = ["ld", "ld.lld", "lld"];
+    for name in &candidates {
+        if let Some(path) = which(name) {
+            return path;
+        }
+    }
+    fail("Failed to find a linker (tried: ld, ld.lld, lld)")
