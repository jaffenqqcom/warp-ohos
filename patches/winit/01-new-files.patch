+/// Phase of a touch event, extracted from OHOS NDK OH_TouchEvent touchType.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub enum TouchPhase {
+    Started,
+    Moved,
+    Ended,
+    Canceled,
+}
+
+/// Key action (pressed or released).
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub enum KeyAction {
+    Pressed,
+    Released,
+}
+
+/// Mouse action (pressed, released, or moved).
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub enum MouseAction {
+    Press,
+    Release,
+    Move,
+}
+
+/// Mouse button identifiers.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub enum MouseButton {
+    Left,
+    Right,
+    Middle,
+    Back,
+    Forward,
+    Other(i32),
+}
+
+/// Payload for IME input events.
+#[derive(Debug, Clone)]
+pub enum ImePayload {
+    /// Text content (e.g., "你好", multi-byte, or ASCII to bypass keybinding).
+    Commit(String),
+    /// IME composition in progress (e.g., unfinished pinyin).
+    Preedit(String),
+    /// IME status change: true=enabled, false=disabled.
+    ImeStatus(bool),
+    /// Key event that should go through the keybinding system.
+    /// key: "enter"/"backspace"/"tab"/"escape", chars: None for control keys,
+    ///      or key == the single ASCII character, chars = Some(character).
+    KeyboardEvent { key: String, chars: Option<String> },
+}
+
+/// Owned + Send event type for the cross-thread event channel between
+/// the ArkTS UI thread (openharmony-ability run_loop) and the warp main thread.
+///
+/// Excludes lifetime-bounded variants (Resume/SaveState from openharmony_ability::Event),
+/// which are handled directly in the run_loop closure.
+pub enum OhosEvent {
+    WindowCreate,
+    WindowDestroy,
+    WindowRedraw,
+    WindowResize(PhysicalSize<u32>),
+    ContentRectChange,
+    AvoidAreaChange,
+    ConfigChanged,
+    LowMemory,
+    Start,
+    GainedFocus,
+    LostFocus,
+    Pause,
+    Stop,
+    Create,
+    Destroy,
+    SurfaceCreate,
+    SurfaceDestroy,
+    TouchEvent(TouchPhase, f64, f64),
+    /// 鼠标事件（与 TouchEvent 分开，用于区分左右键和移动/拖拽）
+    MouseEvent(MouseAction, MouseButton, f64, f64),
+    /// keycode, action, modifier_state（OHOS bitmask: bit0=Ctrl, bit1=Shift, bit2=Alt）
+    KeyEvent(openharmony_ability::xcomponent::KeyCode, KeyAction, u8),
+    ImeEvent(ImePayload),
+    KeyboardEvent(i32),
+    MouseWheel(f64, f64),
+    UserEvent,
+    /// 跨线程用户事件负载（CustomEvent 通过此变体走 EVENT_CHANNEL）
+    UserPayload(Box<dyn std::any::Any + Send>),
+}
+
+impl std::fmt::Debug for OhosEvent {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        match self {
+            Self::UserPayload(_) => f.debug_struct("UserPayload").finish_non_exhaustive(),
+            _ => f.debug_tuple("").finish(),
+        }
+    }
+}
+
+/// Convert an `openharmony_ability::Event` to `OhosEvent` for the cross-thread channel.
+///
+/// This is the bridge between the ability event loop (ArkTS UI thread) and the
+/// winit event loop (warp main thread). `Resume` and `SaveState` variants carry
+/// lifetime-bounded data and are handled directly in the run_loop closure.
+pub fn ability_event_to_ohos_event(event: &openharmony_ability::Event<'_>) -> OhosEvent {
+    use openharmony_ability::InputEvent;
+    match event {
+        openharmony_ability::Event::WindowCreate => OhosEvent::WindowCreate,
+        openharmony_ability::Event::WindowDestroy => OhosEvent::WindowDestroy,
+        openharmony_ability::Event::WindowRedraw(_) => OhosEvent::WindowRedraw,
+        openharmony_ability::Event::WindowResize(size) => {
+            OhosEvent::WindowResize(PhysicalSize::new(size.width as u32, size.height as u32))
+        },
+        openharmony_ability::Event::ContentRectChange(_) => OhosEvent::ContentRectChange,
+        openharmony_ability::Event::AvoidAreaChange(_) => OhosEvent::AvoidAreaChange,
+        openharmony_ability::Event::ConfigChanged(_) => OhosEvent::ConfigChanged,
+        openharmony_ability::Event::LowMemory => OhosEvent::LowMemory,
+        openharmony_ability::Event::Start => OhosEvent::Start,
+        openharmony_ability::Event::GainedFocus => OhosEvent::GainedFocus,
+        openharmony_ability::Event::LostFocus => OhosEvent::LostFocus,
+        openharmony_ability::Event::Pause => OhosEvent::Pause,
+        openharmony_ability::Event::Stop => OhosEvent::Stop,
+        openharmony_ability::Event::Create => OhosEvent::Create,
+        openharmony_ability::Event::Destroy => OhosEvent::Destroy,
+        openharmony_ability::Event::SurfaceCreate => OhosEvent::SurfaceCreate,
+        openharmony_ability::Event::SurfaceDestroy => OhosEvent::SurfaceDestroy,
+        openharmony_ability::Event::KeyboardEvent(v) => OhosEvent::KeyboardEvent(*v),
+        openharmony_ability::Event::UserEvent => OhosEvent::UserEvent,
+        // Input events need to be decomposed from opaque types
+        // InputEvent::KeyEvent 由 ArkTS onKeyEvent 处理，不从 NDK 回调走
+        openharmony_ability::Event::Input(InputEvent::KeyEvent(_)) => OhosEvent::UserEvent,
+        openharmony_ability::Event::Input(InputEvent::TouchEvent(_data)) => {
+            // 触摸事件由 ArkTS onTouch 回调经 NAPI 统一处理（触屏→onWheelEvent
+            // 滚动，鼠标→onMouse 选词）。NDK dispatch_touch_event 路径在此
+            // 跳过，避免：
+            //   1. NDK TouchEvent(Moved) → ScrollWheel(precise=true) 干扰选词
+            //   2. NDK TouchEvent(Ended) → convert_touch_ended 长按检测误触右键菜单
+            OhosEvent::UserEvent
+        },
+        openharmony_ability::Event::Input(InputEvent::ImeEvent(ime)) => {
+            use openharmony_ability::ImeEvent;
+            let payload = match ime {
+                ImeEvent::TextInputEvent(txt) => {
+                    let text = &txt.text;
+                    if text == "\n" || text == "\r" {
+                        ImePayload::KeyboardEvent { key: "enter".into(), chars: Some("\r".into()) }
+                    } else if text == "\x7f" || text == "\x08" {
+                        ImePayload::KeyboardEvent {
+                            key: "backspace".into(),
+                            chars: Some("\x7f".into()),
+                        }
+                    } else if text == "\t" {
+                        ImePayload::KeyboardEvent { key: "tab".into(), chars: Some("\t".into()) }
+                    } else if text == "\x1b" {
+                        ImePayload::KeyboardEvent { key: "escape".into(), chars: None }
+                    } else if text.len() == 1 {
+                        let c = text.chars().next().unwrap();
+                        if c.is_ascii() && !c.is_ascii_control() {
+                            let s = text.clone();
+                            ImePayload::KeyboardEvent { key: s.clone(), chars: Some(s) }
+                        } else {
+                            ImePayload::Commit(text.clone())
+                        }
+                    } else {
+                        ImePayload::Commit(text.clone())
+                    }
+                },
+                ImeEvent::BackspaceEvent(_len) => ImePayload::KeyboardEvent {
+                    key: "backspace".into(),
+                    chars: Some("\x7f".into()),
+                },
+                ImeEvent::ImeStatusEvent(status) => {
+                    use openharmony_ability::ime::KeyboardStatus;
+                    ImePayload::ImeStatus(matches!(status, KeyboardStatus::Show))
+                },
+                ImeEvent::EnterEvent(_key) => {
+                    ImePayload::KeyboardEvent { key: "enter".into(), chars: Some("\r".into()) }
+                },
+            };
+            OhosEvent::ImeEvent(payload)
+        },
+        // Resume and SaveState carry lifetime-bound data; caller handles them directly
+        openharmony_ability::Event::AxisEvent(_, _) => {
+            // Handled directly in ohos_entry.rs run_loop, not through ability_event_to_ohos_event
+            OhosEvent::UserEvent
+        },
+        openharmony_ability::Event::Resume(_) | openharmony_ability::Event::SaveState(_) => {
+            unreachable!(
+                "Resume/SaveState must be handled before calling ability_event_to_ohos_event"
+            )
+        },
+    }
+}
+
+fn ohos_event_to_winit_event<T>(event: &OhosEvent) -> Vec<event::Event<T>> {
+    use event::{Event, WindowEvent};
+
+    match event {
+        OhosEvent::SurfaceCreate => {
+            vec![Event::NewEvents(StartCause::Init), Event::Resumed]
+        },
+        OhosEvent::SurfaceDestroy => vec![Event::Suspended],
+        OhosEvent::WindowResize(size) => {
+            CACHED_SURFACE_SIZE.store(
+                (size.width as u64) << 32 | size.height as u64,
+                std::sync::atomic::Ordering::Release,
+            );
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::Resized(*size),
+            }]
+        },
+        OhosEvent::WindowRedraw => {
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::RedrawRequested,
+            }]
+        },
+        OhosEvent::GainedFocus => {
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::Focused(true),
+            }]
+        },
+        OhosEvent::LostFocus => {
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::Focused(false),
+            }]
+        },
+        OhosEvent::Destroy => {
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::CloseRequested,
+            }]
+        },
+        OhosEvent::LowMemory => vec![Event::MemoryWarning],
+        OhosEvent::TouchEvent(phase, x, y) => {
+            let winit_phase = match phase {
+                TouchPhase::Started => event::TouchPhase::Started,
+                TouchPhase::Ended => event::TouchPhase::Ended,
+                TouchPhase::Canceled => event::TouchPhase::Cancelled,
+                _ => return vec![],
+            };
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::Touch(event::Touch {
+                    device_id: event::DeviceId(DeviceId),
+                    phase: winit_phase,
+                    location: PhysicalPosition::new(*x, *y),
+                    force: None,
+                    id: 0,
+                }),
+            }]
+        },
+        OhosEvent::MouseEvent(action, button, x, y) => {
+            use crate::event::MouseButton as WinitMouseButton;
+            match action {
+                MouseAction::Press => {
+                    let btn = match button {
+                        MouseButton::Left => WinitMouseButton::Left,
+                        MouseButton::Right => WinitMouseButton::Right,
+                        MouseButton::Middle => WinitMouseButton::Middle,
+                        MouseButton::Back => WinitMouseButton::Back,
+                        MouseButton::Forward => WinitMouseButton::Forward,
+                        MouseButton::Other(v) => WinitMouseButton::Other(*v as u16),
+                    };
+                    vec![
+                        // 先发 CursorMoved 更新 last_cursor_position，再发 MouseInput
+                        // winit 的 MouseInput 没有位置字段，warpui 通过 last_cursor_position
+                        // 获取点击位置。（macOS/Linux 的 OS 保证 CursorMoved 先于 MouseInput）
+                        Event::WindowEvent {
+                            window_id: GLOBAL_WINDOW_ID,
+                            event: WindowEvent::CursorMoved {
+                                device_id: event::DeviceId(DeviceId),
+                                position: PhysicalPosition::new(*x, *y),
+                            },
+                        },
+                        Event::WindowEvent {
+                            window_id: GLOBAL_WINDOW_ID,
+                            event: WindowEvent::MouseInput {
+                                device_id: event::DeviceId(DeviceId),
+                                state: event::ElementState::Pressed,
+                                button: btn,
+                            },
+                        },
+                    ]
+                },
+                MouseAction::Release => {
+                    let btn = match button {
+                        MouseButton::Left => WinitMouseButton::Left,
+                        MouseButton::Right => WinitMouseButton::Right,
+                        MouseButton::Middle => WinitMouseButton::Middle,
+                        MouseButton::Back => WinitMouseButton::Back,
+                        MouseButton::Forward => WinitMouseButton::Forward,
+                        MouseButton::Other(v) => WinitMouseButton::Other(*v as u16),
+                    };
+                    vec![
+                        Event::WindowEvent {
+                            window_id: GLOBAL_WINDOW_ID,
+                            event: WindowEvent::CursorMoved {
+                                device_id: event::DeviceId(DeviceId),
+                                position: PhysicalPosition::new(*x, *y),
+                            },
+                        },
+                        Event::WindowEvent {
+                            window_id: GLOBAL_WINDOW_ID,
+                            event: WindowEvent::MouseInput {
+                                device_id: event::DeviceId(DeviceId),
+                                state: event::ElementState::Released,
+                                button: btn,
+                            },
+                        },
+                    ]
+                },
+                MouseAction::Move => {
+                    vec![Event::WindowEvent {
+                        window_id: GLOBAL_WINDOW_ID,
+                        event: WindowEvent::CursorMoved {
+                            device_id: event::DeviceId(DeviceId),
+                            position: PhysicalPosition::new(*x, *y),
+                        },
+                    }]
+                },
+            }
+        },
+        OhosEvent::KeyEvent(keycode, action, modifier_state) => {
+            let state = match action {
+                KeyAction::Pressed => event::ElementState::Pressed,
+                KeyAction::Released => event::ElementState::Released,
+            };
+            let physical_key = keycodes::to_physical_key(*keycode);
+            let logical_key = keycodes::to_logical(*keycode);
+
+            // 从 ArkTS 的 modifierKeyState 直接读取修饰键状态（像 macOS 读 NSEvent.modifierFlags 一样）。
+            // bit0=Ctrl, bit1=Shift, bit2=Alt, bit4=CapsLock
+            let ms = *modifier_state;
+            let ctrl_held = ms & 0x01 != 0;
+            let shift_held = ms & 0x02 != 0;
+            let caps_on = ms & 0x10 != 0;
+
+            let (text, text_with_all_modifiers) =
+                ohos_compute_text(&logical_key, shift_held, caps_on, ctrl_held);
+
+            let mut winit_mods = crate::keyboard::ModifiersState::default();
+            if ms & 0x04 != 0 {
+                winit_mods |= crate::keyboard::ModifiersState::ALT;
+            }
+            if ms & 0x01 != 0 {
+                winit_mods |= crate::keyboard::ModifiersState::CONTROL;
+            }
+            if ms & 0x02 != 0 {
+                winit_mods |= crate::keyboard::ModifiersState::SHIFT;
+            }
+            let mods: crate::event::Modifiers = winit_mods.into();
+            vec![
+                Event::WindowEvent {
+                    window_id: GLOBAL_WINDOW_ID,
+                    event: WindowEvent::ModifiersChanged(mods),
+                },
+                Event::WindowEvent {
+                    window_id: GLOBAL_WINDOW_ID,
+                    event: WindowEvent::KeyboardInput {
+                        device_id: event::DeviceId(DeviceId),
+                        event: event::KeyEvent {
+                            state,
+                            physical_key,
+                            logical_key: logical_key.clone(),
+                            text,
+                            location: keycodes::to_location(*keycode),
+                            repeat: false,
+                            platform_specific: KeyEventExtra {
+                                text_with_all_modifiers,
+                                key_without_modifiers: logical_key,
+                            },
+                        },
+                        is_synthetic: false,
+                    },
+                },
+            ]
+        },
+        OhosEvent::ImeEvent(payload) => {
+            // KeyboardEvent → KeyEvent 路径（查快捷键系统）
+            if let ImePayload::KeyboardEvent { key, chars } = payload {
+                let (physical_key, logical_key, text) = match key.as_str() {
+                    "enter" => (
+                        crate::keyboard::PhysicalKey::Code(crate::keyboard::KeyCode::Enter),
+                        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Enter),
+                        chars.clone().map(SmolStr::from),
+                    ),
+                    "backspace" => (
+                        crate::keyboard::PhysicalKey::Code(crate::keyboard::KeyCode::Backspace),
+                        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Backspace),
+                        chars.clone().map(SmolStr::from),
+                    ),
+                    "tab" => (
+                        crate::keyboard::PhysicalKey::Code(crate::keyboard::KeyCode::Tab),
+                        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Tab),
+                        chars.clone().map(SmolStr::from),
+                    ),
+                    "escape" => (
+                        crate::keyboard::PhysicalKey::Code(crate::keyboard::KeyCode::Escape),
+                        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Escape),
+                        None,
+                    ),
+                    _ => match chars {
+                        Some(ref s) => (
+                            crate::keyboard::PhysicalKey::Unidentified(
+                                crate::keyboard::NativeKeyCode::Unidentified,
+                            ),
+                            crate::keyboard::Key::Character(s.clone().into()),
+                            Some(s.clone().into()),
+                        ),
+                        None => return Vec::new(),
+                    },
+                };
+                // IME 不带修饰键信息，默认清除修饰键状态
+                let mods: crate::event::Modifiers =
+                    crate::keyboard::ModifiersState::default().into();
+                return vec![
+                    Event::WindowEvent {
+                        window_id: GLOBAL_WINDOW_ID,
+                        event: WindowEvent::ModifiersChanged(mods),
+                    },
+                    Event::WindowEvent {
+                        window_id: GLOBAL_WINDOW_ID,
+                        event: WindowEvent::KeyboardInput {
+                            device_id: event::DeviceId(DeviceId),
+                            event: event::KeyEvent {
+                                state: event::ElementState::Pressed,
+                                physical_key,
+                                logical_key: logical_key.clone(),
+                                text,
+                                location: crate::keyboard::KeyLocation::Standard,
+                                repeat: false,
+                                platform_specific: KeyEventExtra {
+                                    text_with_all_modifiers: None,
+                                    key_without_modifiers: logical_key,
+                                },
+                            },
+                            is_synthetic: false,
+                        },
+                    },
+                ];
+            }
+            let ime_event = match payload {
+                ImePayload::Commit(s) => {
+                    tracing::debug!("IME_EVENT: Commit '{}'", s);
+                    event::Ime::Commit(s.clone())
+                },
+                ImePayload::Preedit(s) => {
+                    tracing::debug!("IME_EVENT: Preedit '{}'", s);
+                    event::Ime::Preedit(s.clone(), None)
+                },
+                ImePayload::ImeStatus(true) => {
+                    tracing::info!("IME_EVENT: Show -> Enabled");
+                    event::Ime::Enabled
+                },
+                ImePayload::ImeStatus(false) => {
+                    tracing::info!("IME_EVENT: Hide -> Disabled");
+                    event::Ime::Disabled
+                },
+                ImePayload::KeyboardEvent { .. } => {
+                    unreachable!("KeyboardEvent handled above")
+                },
+            };
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::Ime(ime_event),
+            }]
+        },
+        OhosEvent::MouseWheel(delta_x, delta_y) => {
+            // 缩放：OHOS 轴事件单位是"分"（1/120 秒的滚动量），
+            // 120 = 一个标准滚轮刻度，winit 的 LineDelta 也是每刻度 ~1-3 行。
+            // 转换为 LineDelta 并由 app.rs 处理缩放。
+            vec![Event::WindowEvent {
+                window_id: GLOBAL_WINDOW_ID,
+                event: WindowEvent::MouseWheel {
+                    device_id: event::DeviceId(DeviceId),
+                    delta: event::MouseScrollDelta::LineDelta(*delta_x as f32, *delta_y as f32),
+                    phase: event::TouchPhase::Moved,
+                },
+            }]
+        },
+        // UserEvent: pure vsync wake-up, handled by PENDING_REDRAW in EventLoop::run().
+        OhosEvent::UserEvent => Vec::new(),
+
+        // UserPayload: handled directly in EventLoop::run() before this function.
+        OhosEvent::UserPayload(_) => Vec::new(),
+        // Lifecycle/internal events tracked by openharmony-ability itself;
+        // no winit event conversion needed.
+        OhosEvent::WindowCreate
+        | OhosEvent::WindowDestroy
+        | OhosEvent::ContentRectChange
+        | OhosEvent::AvoidAreaChange
+        | OhosEvent::ConfigChanged
+        | OhosEvent::Start
+        | OhosEvent::Pause
+        | OhosEvent::Stop
+        | OhosEvent::Create
+        | OhosEvent::KeyboardEvent(_) => Vec::new(),
+    }
+}
