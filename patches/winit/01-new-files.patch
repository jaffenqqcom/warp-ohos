+// ── EventLoop ───────────────────────────────────────────────────────────────
+
+pub struct EventLoop<T: 'static> {
+    pub(crate) openharmony_app: OpenHarmonyApp,
+    window_target: crate::event_loop::ActiveEventLoop,
+    _marker: std::marker::PhantomData<T>,
+}
+
+impl<T: 'static> EventLoop<T> {
+    pub fn new(attributes: &PlatformSpecificEventLoopAttributes) -> Result<Self, EventLoopError> {
+        static EVENT_LOOP_CREATED: AtomicBool = AtomicBool::new(false);
+        if EVENT_LOOP_CREATED.swap(true, Ordering::Relaxed) {
+            return Err(EventLoopError::RecreationAttempt);
+        }
+
+        let openharmony_app = attributes.openharmony_app.clone().ok_or_else(|| {
+            EventLoopError::Os(crate::error::OsError::new(
+                line!(),
+                file!(),
+                "OpenHarmonyApp not provided",
+            ))
+        })?;
+
+        // OHOS_APP already registered via OHOS_APP static above.
+        // (set_ohos_app removed to simplify the IME path)
+
+        let inner = ActiveEventLoop {
+            app: openharmony_app.clone(),
+            control_flow: Cell::new(ControlFlow::default()),
+            exit: Cell::new(false),
+        };
+        Ok(Self {
+            window_target: crate::event_loop::ActiveEventLoop {
+                p: inner,
+                _marker: std::marker::PhantomData,
+            },
+            openharmony_app,
+            _marker: std::marker::PhantomData,
+        })
+    }
+
+    pub fn run<F>(self, mut event_handler: F) -> Result<(), EventLoopError>
+    where
+        F: FnMut(event::Event<T>, &event_loop::ActiveEventLoop),
+    {
+        let root_target = self.window_target;
+
+        // 初始化 OH_NativeVSync，以 vsync 频率驱动 RedrawRequested 事件。
+        init_vsync();
+
+        // Read from the global EVENT_CHANNEL (set up by init_ability via expose_event_channel)
+        if let Some((_, rx)) = EVENT_CHANNEL.get() {
+            let rx = rx.lock().unwrap();
+
+            eprintln!("[ohos-el] entering recv loop");
+
+            loop {
+                match rx.recv_timeout(std::time::Duration::from_millis(100)) {
+                    Ok(ohos_event) => {
+                        eprintln!("[ohos-el] event: {:?}", ohos_event);
+                        // UserPayload carries CustomEvent; downcast with ownership of the Box.
+                        // This must be handled here (before ohos_event_to_winit_event) because
+                        // that function takes &OhosEvent and can't move out of the Box.
+                        if let OhosEvent::UserPayload(mut data) = ohos_event {
+                            if let Ok(v) = data.downcast::<T>() {
+                                event_handler(event::Event::UserEvent(*v), &root_target);
+                                if root_target.exiting() {
+                                    break;
+                                }
+                            }
+                        } else {
+                            let winit_events = ohos_event_to_winit_event::<T>(&ohos_event);
+                            for evt in winit_events {
+                                event_handler(evt, &root_target);
+                                if root_target.exiting() {
+                                    break;
+                                }
+                            }
+                            if root_target.exiting() {
+                                break;
+                            }
+                        }
+
+                        // 检查 PENDING_REDRAW 标记，vsync 回调通过 compare_exchange 设置，
+                        // 事件循环通过 swap 原子地取出并清除。
+                        if PENDING_REDRAW.swap(false, Ordering::AcqRel) {
+                            use event::WindowEvent;
+                            event_handler(
+                                event::Event::WindowEvent {
+                                    window_id: GLOBAL_WINDOW_ID,
+                                    event: WindowEvent::RedrawRequested,
+                                },
+                                &root_target,
+                            );
+                            if root_target.exiting() {
+                                break;
+                            }
+                        }
+
+                        // Dispatch AboutToWait once per OhosEvent batch
+                        event_handler(event::Event::AboutToWait, &root_target);
+
+
+                        if root_target.exiting() {
+                            break;
+                        }
+                    },
+                    Err(std::sync::mpsc::RecvTimeoutError::Timeout) => {
+                        // 100ms timeout: dispatch AboutToWait to process
+                        // pending dispatch tasks (e.g. spawn callback).
+                        if PENDING_REDRAW.swap(false, Ordering::AcqRel) {
+                            use event::WindowEvent;
+                            event_handler(
+                                event::Event::WindowEvent {
+                                    window_id: GLOBAL_WINDOW_ID,
+                                    event: WindowEvent::RedrawRequested,
+                                },
+                                &root_target,
+                            );
+                        }
+                        event_handler(event::Event::AboutToWait, &root_target);
+                        if root_target.exiting() {
+                            break;
+                        }
+                    },
+                    Err(_) => break, // channel closed
+                }
+            }
+        }
+
+        // 清理 vsync 资源
+        destroy_vsync();
+
+        Ok(())
+    }
+
+    pub fn window_target(&self) -> &crate::event_loop::ActiveEventLoop {
+        &self.window_target
+    }
+
+    pub fn create_proxy(&self) -> EventLoopProxy<T> {
+        EventLoopProxy {
+            waker: self.openharmony_app.create_waker(),
+            _marker: std::marker::PhantomData,
+        }
+    }
+}
+
+// ── EventLoopProxy ──────────────────────────────────────────────────────────
+
+pub struct EventLoopProxy<T: 'static> {
+    waker: openharmony_ability::OpenHarmonyWaker,
+    _marker: std::marker::PhantomData<T>,
+}
+
+impl<T: 'static> EventLoopProxy<T> {
+    pub fn new(waker: openharmony_ability::OpenHarmonyWaker) -> Self {
+        Self { waker, _marker: std::marker::PhantomData }
+    }
+
+    pub fn wake_up(&self) {
+        // Wake the event loop via OpenHarmonyWaker
+        self.waker.wake();
+    }
+
+    pub fn send_event(&self, event: T) -> Result<(), event_loop::EventLoopClosed<T>>
+    where
+        T: Send,
+    {
+        if let Some((tx, _)) = EVENT_CHANNEL.get() {
+            let _ = tx.send(OhosEvent::UserPayload(Box::new(event)));
+            self.wake_up();
+        }
+        Ok(())
+    }
+}
+
+impl<T: 'static> Clone for EventLoopProxy<T> {
+    fn clone(&self) -> Self {
+        Self { waker: self.waker.clone(), _marker: std::marker::PhantomData }
+    }
+}
+
