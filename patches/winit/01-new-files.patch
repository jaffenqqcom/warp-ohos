+#[derive(Debug)]
+pub struct Window {
+    id: WindowId,
+    /// 持有 OpenHarmonyApp 引用，供 raw_window_handle 查询 native_window 指针。
+    native_window: OpenHarmonyApp,
+    /// 缓存的表面尺寸，由 set_inner_size 更新。避免每帧 query OpenHarmonyApp
+    /// 导致 surface 重配（OpenHarmonyApp::surface_size() 实时读取 XComponent，
+    /// 可能每帧返回不同值）。
+    cached_inner_size: std::sync::atomic::AtomicU64,
+}
+
+impl Window {
+    pub fn new(
+        event_loop: &ActiveEventLoop,
+        _window_attributes: WindowAttributes,
+    ) -> Result<Self, crate::error::OsError> {
+        let initial_size = event_loop
+            .app
+            .surface_size()
+            .map(|(w, h)| (w as u32, h as u32))
+            .unwrap_or((1080, 1920));
+        Ok(Self {
+            id: WindowId,
+            native_window: event_loop.app.clone(),
+            cached_inner_size: std::sync::atomic::AtomicU64::new(
+                (initial_size.0 as u64) << 32 | initial_size.1 as u64,
+            ),
+        })
+    }
+
+    pub fn id(&self) -> WindowId {
+        self.id
+    }
+
+    pub fn request_redraw(&self) {
+        // 主动请求渲染：设置 PENDING_REDRAW 标记，vsync 时 NOT 再自动设置。
+        // 这替换了 vsync 回调中 unconditional 的 PENDING_REDRAW 设置，确保
+        // 渲染只在 request_redraw 调用（通过 invalidate / render_scene）时发生。
+        PENDING_REDRAW.store(true, std::sync::atomic::Ordering::Release);
+        if let Some(channel) = EVENT_CHANNEL.get() {
+            let _ = channel.0.send(OhosEvent::UserEvent);
+        }
+    }
+
+    pub fn pre_present_notify(&self) {}
+
+    pub fn primary_monitor(&self) -> Option<monitor::MonitorHandle> {
+        Some(monitor::MonitorHandle::new())
+    }
+
+    pub fn available_monitors(&self) -> Vec<monitor::MonitorHandle> {
+        vec![monitor::MonitorHandle::new()]
+    }
+
+    pub fn scale_factor(&self) -> f64 {
+        self.native_window.scale() as f64
+    }
+
+    pub fn set_title(&self, _title: &str) {}
+
+    pub fn set_visible(&self, _visible: bool) {}
+
+    pub fn is_visible(&self) -> Option<bool> {
+        Some(true)
+    }
+
+    pub fn set_resizable(&self, _resizable: bool) {}
+
+    pub fn is_resizable(&self) -> bool {
+        true
+    }
+
+    pub fn set_minimized(&self, _minimized: bool) {}
+
+    pub fn set_maximized(&self, _maximized: bool) {}
+
+    pub fn is_maximized(&self) -> bool {
+        false
+    }
+
+    pub(crate) fn set_fullscreen(&self, _monitor: Option<Fullscreen>) {}
+
+    pub(crate) fn fullscreen(&self) -> Option<Fullscreen> {
+        None
+    }
+
+    pub fn set_decorations(&self, _decorations: bool) {}
+
+    pub fn is_decorated(&self) -> bool {
+        true
+    }
+
+    pub fn set_window_level(&self, _level: WindowLevel) {}
+
+    pub fn set_cursor(&self, _cursor: crate::cursor::Cursor) {}
+
+    pub fn set_cursor_position(
+        &self,
+        _position: Position,
+    ) -> Result<(), crate::error::ExternalError> {
+        Ok(())
+    }
+
+    pub fn set_cursor_grab(
+        &self,
+        _mode: crate::window::CursorGrabMode,
+    ) -> Result<(), crate::error::ExternalError> {
+        Ok(())
+    }
+
+    pub fn cursor_grab(
+        &self,
+    ) -> Result<crate::window::CursorGrabMode, crate::error::ExternalError> {
+        Ok(crate::window::CursorGrabMode::None)
+    }
+
+    pub fn set_cursor_hittest(&self, _hittest: bool) -> Result<(), crate::error::ExternalError> {
+        Ok(())
+    }
+
+    pub fn set_resize_increments(&self, _increments: Option<Size>) {}
+
+    pub fn resize_increments(&self) -> Option<PhysicalSize<u32>> {
+        None
+    }
+
+    pub fn set_min_size(&self, _dimensions: Option<PhysicalSize<u32>>) {}
+
+    pub fn set_min_inner_size(&self, _size: Option<Size>) {}
+
+    pub fn set_max_size(&self, _dimensions: Option<PhysicalSize<u32>>) {}
+
+    pub fn set_max_inner_size(&self, _size: Option<Size>) {}
+
+    pub fn set_ime_allowed(&self, allowed: bool) {
+        tracing::info!("OHOS_WINDOW::set_ime_allowed: allowed={}", allowed);
+        if allowed {
+            self.native_window.show_keyboard();
+        } else {
+            self.native_window.hide_keyboard();
+        }
+    }
+
+    pub fn set_ime_cursor_area(&self, area: Position, size: Size) {
+        tracing::info!("OHOS_WINDOW::set_ime_cursor_area: area={:?} size={:?}", area, size);
+        // 存储光标位置供 IME 回调查询
+        if let Ok(mut rect) = IME_CURSOR_RECT.lock() {
+            let (x, y) = match area {
+                Position::Logical(p) => (p.x, p.y),
+                Position::Physical(p) => (p.x as f64, p.y as f64),
+            };
+            let (w, h) = match size {
+                Size::Logical(s) => (s.width, s.height),
+                Size::Physical(s) => (s.width as f64, s.height as f64),
+            };
+            *rect = Some((x, y, w, h));
+        }
+    }
+
+    pub fn set_ime_purpose(&self, purpose: ImePurpose) {
+        tracing::info!("OHOS_WINDOW::set_ime_purpose: purpose={:?}", purpose);
+    }
+
+    pub fn set_ime_position(&self, position: PhysicalPosition<i32>) {
+        tracing::info!("OHOS_WINDOW::set_ime_position: position={:?}", position);
+    }
+
+    pub fn current_monitor(&self) -> Option<monitor::MonitorHandle> {
+        Some(monitor::MonitorHandle::new())
+    }
+
+    pub fn inner_size(&self) -> PhysicalSize<u32> {
+        let packed = CACHED_SURFACE_SIZE.load(std::sync::atomic::Ordering::Acquire);
+        let w = (packed >> 32) as u32;
+        let h = packed as u32;
+        if w > 0 && h > 0 {
+            PhysicalSize::new(w, h)
+        } else {
+            let packed = self.cached_inner_size.load(std::sync::atomic::Ordering::Relaxed);
+            PhysicalSize::new(w, h)
+        }
+    }
+
+    /// 从外部（Resized 事件）更新缓存的 surface 尺寸。
+    pub fn set_inner_size(&self, size: PhysicalSize<u32>) {
+        self.cached_inner_size.store(
+            (size.width as u64) << 32 | size.height as u64,
+            std::sync::atomic::Ordering::Relaxed,
+        );
+    }
+
+    pub fn request_inner_size(&self, _size: Size) -> Option<PhysicalSize<u32>> {
+        None
+    }
+
+    pub fn reset_dead_keys(&self) {}
+
+    pub fn focus_window(&self) {}
+
+    pub fn request_user_attention(&self, _request_type: Option<crate::window::UserAttentionType>) {}
+
+    pub fn set_blur(&self, _blur: bool) {}
+
