+use crate::monitor::MonitorHandle as RootMonitorHandle;
+
+#[derive(Debug, Clone, PartialEq, Eq, Hash, PartialOrd, Ord)]
+pub struct MonitorHandle;
+
+impl MonitorHandle {
+    pub fn new() -> Self {
+        Self
+    }
+
+    pub fn name(&self) -> Option<String> {
+        None
+    }
+
+    pub fn native_identifier(&self) -> u32 {
