+// ── OH_NativeVSync (vsync 定时器) ──────────────────────────────────────────
+
+#[link(name = "native_vsync")]
+extern "C" {
+    fn OH_NativeVSync_Create(name: *const u8, len: u32) -> *mut c_void;
+    fn OH_NativeVSync_Destroy(vsync: *mut c_void);
+    fn OH_NativeVSync_RequestFrame(
