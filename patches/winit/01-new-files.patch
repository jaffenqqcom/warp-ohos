+        KeyCode::Semicolon => Key::Character(";".into()),
+        KeyCode::Apostrophe => Key::Character("\'".into()),
+        KeyCode::Comma => Key::Character(",".into()),
+        KeyCode::Period => Key::Character(".".into()),
