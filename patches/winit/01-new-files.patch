+#[derive(Clone, Debug, Default)]
+pub struct PlatformSpecificWindowAttributes;
+
+// ── Event channel (winit ↔ warp cross-thread bridge) ───────────────────────
+
+pub(crate) static CACHED_SURFACE_SIZE: std::sync::atomic::AtomicU64 =
+    std::sync::atomic::AtomicU64::new(0);
+
+pub(crate) static EVENT_CHANNEL: OnceLock<(Sender<OhosEvent>, Mutex<Receiver<OhosEvent>>)> =
+    OnceLock::new();
+
+/// Expose the event channel sender side for warp-winit's ohos_entry.rs to register.
+/// Called from init_ability before EventLoop is created.
+pub fn expose_event_channel() -> Sender<OhosEvent> {
+    let (tx, rx) = mpsc::channel();
+    EVENT_CHANNEL.set((tx.clone(), Mutex::new(rx))).ok();
+    tx
+}
+
+// ── OH_NativeVSync (vsync 定时器) ──────────────────────────────────────────
+
+#[link(name = "native_vsync")]
+extern "C" {
+    fn OH_NativeVSync_Create(name: *const u8, len: u32) -> *mut c_void;
+    fn OH_NativeVSync_Destroy(vsync: *mut c_void);
+    fn OH_NativeVSync_RequestFrame(
+        vsync: *mut c_void,
+        callback: Option<unsafe extern "C" fn(i64, *mut c_void)>,
+        data: *mut c_void,
+    ) -> i32;
+}
+
+/// 全局 vsync 实例，在 EventLoop::run() 中初始化。
+static VSYNC_INSTANCE: Mutex<Option<VsyncPtr>> = Mutex::new(None);
+
+/// 渲染待处理标记。替代将 WindowRedraw 事件塞入 mpsc 队列的方式。
+/// vsync 回调：原子检查-设置，若上一帧尚未渲染则跳过当前帧。
+/// 事件循环：处理完事件后检查此标记，只发一次 RedrawRequested。
+static PENDING_REDRAW: AtomicBool = AtomicBool::new(false);
+
+/// 全局 IME 光标位置。由 set_ime_cursor_area/set_ime_position 更新，
+/// 供 OhosDelegate 在 IME 回调中查询使用。
+/// (left, top, width, height) 逻辑像素坐标。
+static IME_CURSOR_RECT: Mutex<Option<(f64, f64, f64, f64)>> = Mutex::new(None);
+
+
+/// 获取当前的 IME 光标位置。
+/// 返回 Option<(left, top, width, height)>，逻辑像素坐标。
+pub fn ime_cursor_rect() -> Option<(f64, f64, f64, f64)> {
+    IME_CURSOR_RECT.lock().ok().and_then(|r| *r)
+}
+
+/// 模拟 macOS/Linux 键盘布局的 text_with_all_modifiers 行为。
+///
+/// macOS/Linux 的 `text_with_all_modifiers()` 返回 OS 键盘布局在所有修饰键作用下的
+/// 最终字符输出。OHOS 没有真实键盘布局，通过此函数手动模拟 US QWERTY 布局的行为：
+///
+/// 优先级：
+/// 1. Ctrl 优先 — 输出 ASCII 控制字符（如 ctrl+a → "\x01"），Shift 被忽略
+/// 2. Shift — 小写字母→大写，符号→US QWERTY 上档符号（如 shift+1 → "!"）
+/// 3. 无修饰键 — 直接输出键盘映射的基字
+///
+/// 返回 `(text, text_with_all_modifiers)`。Ctrl 组合键时 text=None（匹配标准 winit 行为）。
+fn ohos_compute_text(
+    logical_key: &crate::keyboard::Key,
+    shift_held: bool,
+    caps_on: bool,
+    ctrl_held: bool,
+) -> (Option<SmolStr>, Option<SmolStr>) {
+    // 1. Ctrl 按下：text=None（让应用程序层处理按键绑定，如 Ctrl+V → 粘贴）
+    //    text_with_all_modifiers=控制字符（warp 输入系统通过此字段发送控制字符到 PTY）
+    //    此行为匹配标准 winit（macOS/Linux），Ctrl+字母组合不产生 text。
+    if ctrl_held {
+        if let crate::keyboard::Key::Character(c) = logical_key {
+            if let Some(ch) = c.chars().next() {
+                if ch.is_ascii() {
+                    let control_byte = (ch as u8) & 0x1F;
+                    let control_str: SmolStr = String::from_utf8(vec![control_byte])
+                        .unwrap_or_else(|_| c.to_string())
+                        .into();
+                    return (None, Some(control_str));
+                }
+            }
+        }
+    }
+
+    // 2. Shift/CapsLock 处理
+    if shift_held || caps_on {
+        if let crate::keyboard::Key::Character(c) = logical_key {
+            if let Some(ch) = c.chars().next() {
+                let shift_xor_caps = shift_held != caps_on;
+                let shifted = match ch {
+                    'a'..='z' if shift_xor_caps => ((ch as u8) - 32) as char,
+                    'A'..='Z' if shift_xor_caps => ((ch as u8) + 32) as char,
+                    'a'..='z' | 'A'..='Z' => ch,
+                    '1' if shift_held => '!',
+                    '2' if shift_held => '@',
+                    '3' if shift_held => '#',
+                    '4' if shift_held => '$',
+                    '5' if shift_held => '%',
+                    '6' if shift_held => '^',
+                    '7' if shift_held => '&',
+                    '8' if shift_held => '*',
+                    '9' if shift_held => '(',
+                    '0' if shift_held => ')',
+                    '-' if shift_held => '_',
+                    '=' if shift_held => '+',
+                    '[' if shift_held => '{',
+                    ']' if shift_held => '}',
+                    '\\' if shift_held => '|',
+                    ';' if shift_held => ':',
+                    '\'' if shift_held => '"',
+                    ',' if shift_held => '<',
+                    '.' if shift_held => '>',
+                    '/' if shift_held => '?',
+                    '`' if shift_held => '~',
+                    _ => ch,
+                };
+                let shifted: SmolStr = shifted.to_string().into();
+                return (Some(shifted.clone()), Some(shifted));
+            }
+        }
+    }
+
+    // 3. 无特殊修饰键：输出基字
+    match logical_key {
+        crate::keyboard::Key::Character(c) => {
+            let s: SmolStr = c.clone().into();
+            (Some(s.clone()), Some(s))
+        },
+        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Tab) => {
+            (Some("\t".into()), Some("\t".into()))
+        },
+        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Enter) => {
+            (Some("\r".into()), Some("\r".into()))
+        },
+        crate::keyboard::Key::Named(crate::keyboard::NamedKey::Backspace) => {
+            (Some("\x7f".into()), Some("\x7f".into()))
+        },
+        _ => (None, None),
+    }
+}
+
+/// vsync 回调：原子设标记并以 UserEvent 唤醒事件循环。
+/// 标记已设时跳过（上一帧渲染尚未处理），防止渲染事件在队列中堆积。
+extern "C" fn ohos_vsync_callback(_timestamp: i64, _data: *mut c_void) {
+    // OHOS: vsync 回调不再无条件设置 PENDING_REDRAW——request_redraw()
+    // 负责在需要绘制时设置标记。vsync 只做帧率同步：
+    // 如果有 PENDING_REDRAW，发送 UserEvent 唤醒事件循环执行渲染。
+    // 这避免了 60fps 全速渲染带来的性能问题。
+    if PENDING_REDRAW.load(std::sync::atomic::Ordering::Acquire) {
+        if let Some(channel) = EVENT_CHANNEL.get() {
+            let _ = channel.0.send(OhosEvent::UserEvent);
+        }
+    }
+    if let Ok(guard) = VSYNC_INSTANCE.lock() {
+        if let Some(vsync) = guard.as_ref() {
+            unsafe {
+                OH_NativeVSync_RequestFrame(
+                    vsync.0,
+                    Some(ohos_vsync_callback as unsafe extern "C" fn(i64, *mut c_void)),
+                    std::ptr::null_mut(),
+                );
+            }
+        }
+    }
+}
+
+/// 初始化 OH_NativeVSync 并注册回调。
+fn init_vsync() {
+    let mut guard = VSYNC_INSTANCE.lock().unwrap();
+    if guard.is_some() {
+        return;
+    }
+    let name = b"warp_vsync\0";
+    let vsync = unsafe { OH_NativeVSync_Create(name.as_ptr(), (name.len() - 1) as u32) };
+    if let Some(ptr) = NonNull::new(vsync) {
+        let vsync_ptr = VsyncPtr(ptr.as_ptr());
+        *guard = Some(vsync_ptr);
+        unsafe {
+            OH_NativeVSync_RequestFrame(
+                ptr.as_ptr(),
+                Some(ohos_vsync_callback as unsafe extern "C" fn(i64, *mut c_void)),
+                std::ptr::null_mut(),
+            );
+        }
+    }
+}
+
+/// 销毁 vsync 实例。
+fn destroy_vsync() {
+    let mut guard = VSYNC_INSTANCE.lock().unwrap();
+    if let Some(vsync) = guard.take() {
+        unsafe { OH_NativeVSync_Destroy(vsync.0) };
+    }
+}
